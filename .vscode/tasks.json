{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Fund App",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Open Fund App",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"start",
				"",
				"http://localhost:5500"
			],
			"isBackground": false,
			"group": "build"
		}
	]
}