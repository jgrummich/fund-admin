{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Fund App",
			"type": "shell",
			"command": "python",
			"args": [
				"-m",
				"http.server",
				"5500"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Open Fund App",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"start",
				"",
				"index.html"
			],
			"isBackground": false,
			"group": "build"
		}
	]
}